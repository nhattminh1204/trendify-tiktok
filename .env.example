# Trendify — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Application ───────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=Host=localhost;Port=5432;Database=trendify;Username=trendify;Password=changeme
DATABASE_MAX_POOL_SIZE=20

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=localhost:6379
REDIS_PASSWORD=changeme

# ─── MinIO (Storage) ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_ASSETS=trendify-assets
MINIO_USE_SSL=false

# ─── OpenSearch ────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=changeme

# ─── JWT ───────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./certs/private.pem    # RS256 private key
JWT_PUBLIC_KEY_PATH=./certs/public.pem      # RS256 public key
JWT_ISSUER=trendify
JWT_AUDIENCE=trendify-clients
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ─── Token Encryption (for OAuth tokens) ──────────────────────────
TOKEN_ENCRYPTION_KEY=changeme-32-char-key-here  # AES-256 key (32 chars)

# ─── TikTok API ────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=changeme
TIKTOK_CLIENT_SECRET=changeme
TIKTOK_REDIRECT_URI=http://localhost:5000/api/v1/auth/tiktok/callback

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-changeme
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ─── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-changeme
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# ─── Google Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=changeme
GEMINI_DEFAULT_MODEL=gemini-1.5-flash

# ─── ElevenLabs (Voice Generation) ────────────────────────────────
ELEVENLABS_API_KEY=changeme

# ─── Hangfire ──────────────────────────────────────────────────────
HANGFIRE_DASHBOARD_USERNAME=admin
HANGFIRE_DASHBOARD_PASSWORD=changeme

# ─── Seq (Log Aggregator) ──────────────────────────────────────────
SEQ_URL=http://localhost:5341
SEQ_API_KEY=changeme

# ─── AI Budget Defaults ────────────────────────────────────────────
AI_BUDGET_FREE_TIER_USD=2.00
AI_BUDGET_PRO_TIER_USD=20.00
AI_BUDGET_AGENCY_TIER_USD=100.00

# ─── Frontend (Next.js) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
