{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (Trendify.Api)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/src/backend/Trendify.Api/bin/Debug/net8.0/Trendify.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/backend/Trendify.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
